{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "no-inline-styles": "off",
    "manifest-file-extension": "off",
    "apple-touch-icons": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "border-color: color-mix(in srgb, var(--gold) 30%, transparent)",
          "border-color: color-mix(in srgb, var(--gold) 25%, transparent)"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 26.1",
    "not safari <= 26.2"
  ]
}